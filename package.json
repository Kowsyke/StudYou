{
  "name": "studyou",
  "private": true,
  "version": "0.2.0",
  "scripts": {
    "dev": "pnpm --parallel -r --filter @studyou/server --filter @studyou/client dev",
    "build": "pnpm -r build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "pnpm --filter @studyou/engine test && pnpm --filter @studyou/server test",
    "test:e2e": "playwright test",
    "db:generate": "pnpm --filter @studyou/db generate",
    "db:migrate": "pnpm --filter @studyou/db migrate",
    "db:seed": "pnpm --filter @studyou/db seed",
    "db:studio": "pnpm --filter @studyou/db studio",
    "bootstrap": "docker compose -f docker/docker-compose.yml up -d && pnpm install && pnpm db:migrate && pnpm db:seed"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.53.0",
    "typescript": "^5.8.3"
  }
}
